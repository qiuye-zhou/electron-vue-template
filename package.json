{
  "name": "electron-vue-template",
  "version": "1.0.0",
  "description": "Electron + Vue 3 + Vite 开发模板",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vue-tsc && vite build",
    "build:win": "pnpm run build:web && electron-builder --win --publish=never",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "vue3",
    "vite",
    "desktop",
    "app"
  ],
  "author": "秋叶ゞ",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rollup-plugin-copy": "^3.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vue-tsc": "^3.0.8",
    "wait-on": "^9.0.0"
  },
  "dependencies": {
    "vue": "^3.4.0"
  }
}